@using webCompilerInterpreter.Models
@model webCompilerInterpreter.Models.CompilerViewModel

@{
    ViewData["Title"] = "Online Compiler";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Online Compiler</title>

    @* Google Fonts: JetBrains Mono for code feel, Chakra Petch for headers *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg: #080c10;          /* page background */
            --surface: #0e1420;     /* card/panel background */
            --border: #1e2d40;      /* subtle panel borders */
            --accent: #00e5ff;      /* cyan highlight */
            --accent-dim: rgba(0, 229, 255, 0.12);
            --text: #cdd6e0;        /* primary text */
            --muted: #445566;       /* de-emphasised labels */
            --success: #00e5a0;     /* normal output */
            --error: #ff4f4f;       /* error output */
            --font-code: 'JetBrains Mono', monospace;
            --font-ui: 'Chakra Petch', sans-serif;
            --radius: 4px;
        }
        *, *::before, *::after
        {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        html, body
        {
            height: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-code);
            font-size: 14px;
            line-height: 1.6;
        }
        body::after
        {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent 0px, transparent 3px,
                rgba(0,0,0,0.06) 3px, rgba(0,0,0,0.06) 4px
            );
            pointer-events: none;
            z-index: 9999;
        }
        .shell
        {
            display: grid;
            grid-template-rows: 52px 1fr;
            min-height: 100vh;
        }
        header
        {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 0 28px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
        }
        .logo
        {
            font-family: var(--font-ui);
            font-size: 18px;
            letter-spacing: .12em;
            color: var(--accent);
            text-shadow: 0 0 18px rgba(0,229,255,.45);
        }
        .logo span
        { 
            color: var(--text); 
            font-size: 12px; 
            letter-spacing: .2em; 
            opacity: .5; 
        }
        .workspace
        {
            display: grid;
            grid-template-columns: 220px 1fr;
            overflow: hidden;
        }
        .lang-sidebar
        {
            background: var(--surface);
            border-right: 1px solid var(--border);
            padding: 24px 0;
            display: flex;
            flex-direction: column;
            gap: 2px;
            overflow-y: auto;
        }
        .sidebar-title
        {
            font-family: var(--font-ui);
            font-size: 10px;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0 20px 14px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 8px;
        }
        .lang-option
        {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 9px 20px;
            cursor: pointer;
            position: relative;
            transition: background .15s;
        }

        .lang-option:hover 
        { 
            background: var(--accent-dim);
        }

        .lang-option input[type="radio"] {
            appearance: none;
            -webkit-appearance: none;
            width: 13px;
            height: 13px;
            border: 1.5px solid var(--muted);
            border-radius: 50%;
            flex-shrink: 0;
            transition: border-color .15s, background .15s;
        }
        .lang-option input[type="radio"]:checked
        {
            border-color: var(--accent);
            background: var(--accent);
            box-shadow: 0 0 8px rgba(0,229,255,.5);
        }
        .lang-option input[type="radio"]:checked::after
        {
            content: '';
            display: block;
            width: 5px;
            height: 5px;
            background: var(--bg);
            border-radius: 50%;
            margin: 3px auto 0;
        }
        .lang-option:has(input:checked)::before
        {
            content: '';
            position: absolute;
            left: 0; top: 0; bottom: 0;
            width: 2px;
            background: var(--accent);
            box-shadow: 0 0 6px var(--accent);
        }
        .lang-option .lang-label
        {
            font-size: 13px;
            color: var(--muted);
            transition: color .15s;
        }
        .lang-option:has(input:checked) .lang-label
        { 
            color: var(--accent); 
        }
        .right-pane 
        {
            display: grid;
            grid-template-rows: 1fr auto;
            overflow: hidden;
        }
        .pane-bar 
        {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 18px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            font-size: 11px;
            letter-spacing: .12em;
            color: var(--muted);
            text-transform: uppercase;
            font-family: var(--font-ui);
        }
        .editor-section
        {
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        #compiler-form
        {
            display: flex;
            flex-direction: column;
            flex: 1;
            overflow: hidden;
        }
        #code-input
        {
            flex: 1;
            width: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-code);
            font-size: 14px;
            line-height: 1.75;
            border: none;
            outline: none;
            resize: none;
            padding: 20px 24px;
            tab-size: 4;
            caret-color: var(--accent);
            min-height: 260px;
        }
        #code-input::placeholder
        {
            color: var(--muted);
        }
        #code-input::selection
        {
            background: rgba(0,229,255,.15);
        }
        .run-row
        {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 12px 18px;
            background: var(--surface);
            border-top: 1px solid var(--border);
        }
        #run-btn
        {
            font-family: var(--font-ui);
            font-size: 13px;
            font-weight: 700;
            letter-spacing: .18em;
            text-transform: uppercase;
            background: var(--accent);
            color: var(--bg);
            border: none;
            padding: 10px 30px;
            cursor: pointer;
            clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
            transition: box-shadow .2s, transform .1s;
        }
        #run-btn:hover
        {
            box-shadow: 0 0 28px rgba(0,229,255,.55);
            transform: translateY(-1px);
        }
        #run-btn:active
        {
            transform: translateY(0);
        }
        #run-btn:disabled
        {
            opacity: .4;
            cursor: not-allowed;
        }
        .shortcut-hint {
            font-size: 11px;
            color: var(--muted);
            letter-spacing: .08em;
        }
        #spinner
        {
            display: none;
            width: 15px;
            height: 15px;
            border: 2px solid var(--muted);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin .7s linear infinite;
        }
        @@keyframes spin
        {
            to
            {
                transform: rotate(360deg);
            }
        }
        .output-section
        {
            display: flex;
            flex-direction: column;
            border-top: 1px solid var(--border);
            max-height: 38vh;
        }
        #output-display
        {
            flex: 1;
            overflow-y: auto;
            padding: 18px 24px;
            font-family: var(--font-code);
            font-size: 13px;
            line-height: 1.8;
            white-space: pre-wrap;
            word-break: break-word;
            min-height: 80px;
        }
        #output-display.state-idle
        {
            color: var(--muted);
            font-style: italic;
        }
        #output-display.state-success
        {
            color: var(--success);
        }
        #output-display.state-error
        {
            color: var(--error);
        }
        .output-meta
        {
            display: flex;
            gap: 24px;
            padding: 7px 18px;
            font-size: 11px;
            color: var(--muted);
            background: var(--surface);
            border-top: 1px solid var(--border);
            letter-spacing: .08em;
        }
        .meta-ok
        {
            color: var(--success);
        }
        .meta-err
        {
            color: var(--error);
        }
        @@media (max-width: 700px)
        {
            .workspace
            {
                grid-template-columns: 1fr;
                grid-template-rows: auto 1fr;
            }
            .lang-sidebar
            {
                flex-direction: row;
                flex-wrap: wrap;
                border-right: none;
                border-bottom: 1px solid var(--border);
                padding: 10px;
                gap: 6px;
            }
            .sidebar-title
            {
                display: none;
            }
            .lang-option
            {
                border: 1px solid var(--border);
                padding: 5px 12px;
                border-radius: var(--radius);
            }
            .lang-option:has(input:checked)
            {
                border-color: var(--accent);
                background: var(--accent-dim);
            }
            .lang-option:has(input:checked)::before
            {
                display: none;
            }
        }
    </style>
</head>
<body>
<div class="shell">
    <header>
        <div class="logo">Online Compiler</div>
    </header>
    <div class="workspace">
        <aside class="lang-sidebar">
            <div class="sidebar-title">Language</div>

            @foreach (var lang in CompilerViewModel.SupportedLanguages)
            {
                <label class="lang-option">
                    <input type="radio"
                           name="SelectedLanguage"
                           value="@lang.Key"
                           form="compiler-form"
                           @(Model.SelectedLanguage == lang.Key ? "checked" : "") />
                    <span class="lang-label">@lang.Value</span>
                </label>
            }
        </aside>
        <div class="right-pane">
            <section class="editor-section">
                <div class="pane-bar">
                    <span>editor</span>
                    <span id="active-lang-label">
                        @(CompilerViewModel.SupportedLanguages.GetValueOrDefault
                        (Model.SelectedLanguage, "unknown"))
                    </span>
                </div>

                @*
                    THE FORM
                    ─────────────────────────────────────────────────────────
                    asp-action / asp-controller → generates action="/Compiler/Run"
                    method="post"               → HTTP POST on submit
                    id="compiler-form"          → the radio buttons in the sidebar
                                                  reference this via form="compiler-form"
                                                  so they're included in the submission
                                                  even though they're outside the <form> tag.
                *@
                <form id="compiler-form"
                      asp-action="Run"
                      asp-controller="Compiler"
                      method="post">

                    @* CSRF protection token — required by [ValidateAntiForgeryToken] *@
                    @Html.AntiForgeryToken()

                    @*
                        THE TEXTAREA
                        asp-for="Code" does two things automatically:
                          1. Sets name="Code" so MVC can bind to CompilerViewModel.Code
                          2. Sets id="Code"

                        The content between the tags pre-fills the textarea
                        with whatever code was last submitted (so it persists
                        after the page reloads with output).
                    *@
                    <textarea id="code-input"
                              asp-for="Code"
                              spellcheck="false"
                              autocomplete="off"
                              autocorrect="off"
                              autocapitalize="off"
                              placeholder="# Write your Python code here…&#10;print('Hello, world!')">@Model.Code</textarea>

                    @* ── Run button row ──────────────────────────────── *@
                    <div class="run-row">
                        @*
                            THE BUTTON
                            type="submit" — submits the form to /Compiler/Run
                        *@
                        <button type="submit" id="run-btn">▶ Run</button>

                        @* Spinner shown while awaiting the server response *@
                        <div id="spinner"></div>

                        <span class="shortcut-hint">Ctrl + Enter</span>
                    </div>

                </form>
            </section>

            @* ── Output section ─────────────────────────────────────────── *@
            <section class="output-section">

                <div class="pane-bar">
                    <div class="traffic-lights">
                        <div class="tl tl-r"></div>
                        <div class="tl tl-y"></div>
                        <div class="tl tl-g"></div>
                    </div>
                    <span>output</span>
                    @* Execution time — only shown after a run *@
                    <span>
                        @if (Model.ExecutionTimeMs.HasValue)
                        {
                            <span class="@(Model.IsError ? "meta-err" : "meta-ok")">
                                @Model.ExecutionTimeMs ms
                            </span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>

                @*
                    THE OUTPUT PARAGRAPH
                    ─────────────────────────────────────────────────────────
                    This is the element that displays the result. We use a <p>
                    (styled with white-space: pre-wrap) rather than <pre> because
                    it's easier to control with Tailwind-like utility styles.

                    The CSS class is set server-side by Razor:
                      • state-idle    → grey  (no run yet)
                      • state-success → green (clean exit)
                      • state-error   → red   (non-zero exit / stderr)

                    Model.Output is HTML-encoded by Razor by default, so any
                    < > & characters in the output are safe.
                *@
                @{
                    // Determine the display class based on model state.
                    // We compute it in a C# block so the Razor line stays readable.
                    string outputClass = Model.Output == null
                        ? "state-idle"
                        : (Model.IsError ? "state-error" : "state-success");

                    string outputText = Model.Output
                        ?? "// Output will appear here after you click Run…";
                }

                <p id="output-display" class="@outputClass">@outputText</p>

                @* Status bar *@
                <div class="output-meta">
                    @if (Model.Output != null)
                    {
                        <span class="@(Model.IsError ? "meta-err" : "meta-ok")">
                            @(Model.IsError ? "✖ error" : "✔ success")
                        </span>
                        <span>@Model.SelectedLanguage</span>
                        @if (Model.ExecutionTimeMs.HasValue)
                        {
                            <span>@Model.ExecutionTimeMs ms</span>
                        }
                    }
                    else
                    {
                        <span>ready</span>
                    }
                </div>

            </section>
        </div>
    </div>
</div>

@* ═════════════════════════════════════════════════════════════════──────
   JAVASCRIPT
   ────────────────────────────────────────────────────────────────────────
   Kept intentionally minimal — no framework needed.
   Responsibilities:
     1. Ctrl+Enter keyboard shortcut to submit the form.
     2. Show spinner / disable button while the request is in-flight.
     3. Keep the "active language" label in the editor header in sync
        with whichever radio button is selected.
════════════════════════════════════════════════════════════════════════ *@
<script>
(function () {
    "use strict";

    // ── Element references ─────────────────────────────────────────────
    const form        = document.getElementById('compiler-form');
    const textarea    = document.getElementById('code-input');
    const runBtn      = document.getElementById('run-btn');
    const spinner     = document.getElementById('spinner');
    const langLabel   = document.getElementById('active-lang-label');
    const radioInputs = document.querySelectorAll('input[name="SelectedLanguage"]');

    // ── 1. Ctrl+Enter shortcut ─────────────────────────────────────────
    // Allows power users to run code without reaching for the mouse.
    textarea.addEventListener('keydown', function (e) {
        if (e.ctrlKey && e.key === 'Enter') {
            e.preventDefault();      // stop default newline insertion
            form.requestSubmit();    // equivalent to clicking the submit button
        }
    });

    // ── 2. Tab key inserts spaces instead of shifting focus ────────────
    // By default, Tab moves keyboard focus away from the textarea.
    // Override it to insert 4 spaces — more useful for a code editor.
    textarea.addEventListener('keydown', function (e) {
        if (e.key === 'Tab') {
            e.preventDefault();

            // document.execCommand is deprecated but still universally
            // supported and correctly integrates with the browser's undo stack.
            // Modern replacement: use Selection API (more verbose).
            document.execCommand('insertText', false, '    ');
        }
    });

    // ── 3. Spinner + button disable on submit ─────────────────────────
    // Gives the user visual feedback that the server is working.
    // Without this the page just sits there looking frozen for up to
    // 10 seconds (our timeout) while Python runs.
    form.addEventListener('submit', function () {
        runBtn.disabled       = true;
        runBtn.style.display  = 'none';
        spinner.style.display = 'block';
    });

    // ── 4. Sync language label in the editor bar ───────────────────────
    // When the user picks a different language radio button, update
    // the small label in the top-right of the editor pane bar.
    radioInputs.forEach(function (radio) {
        radio.addEventListener('change', function () {
            if (radio.checked) {
                // The label text is the sibling .lang-label span
                const labelSpan = radio.closest('.lang-option').querySelector('.lang-label');
                if (labelSpan) {
                    langLabel.textContent = labelSpan.textContent;
                }
            }
        });
    });

}());
</script>
</body>
</html>