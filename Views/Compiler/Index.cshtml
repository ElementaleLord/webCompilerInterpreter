@using webCompilerInterpreter.Models
@model webCompilerInterpreter.Models.CompilerViewModel
@{
    ViewData["Title"] = "Online Compiler";
    Layout = "_Layout";
}
@section Styles
{
<style>
    main
    {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 52px);
        overflow: hidden;
    }
    .workspace
    {
        display: grid;
        grid-template-columns: 220px 1fr;
        flex: 1;
        overflow: hidden;
    }
    /* LANGUAGE MENU  */
    .lang-sidebar
    {
        background: var(--surface);
        border-right: 1px solid var(--border);
        padding: 24px 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow-y: auto;
    }
    .sidebar-title
    {
        font-family: var(--font-ui);
        font-size: 10px;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 0 20px 14px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 8px;
    }
    .lang-option
    {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 20px;
        cursor: pointer;
        position: relative;
        transition: background .15s;
    }
    .lang-option:hover
    {
        background: var(--accent-dim);
    }
    .lang-option input[type="radio"]
    {
        appearance: none;
        -webkit-appearance: none;
        width: 13px;
        height: 13px;
        border: 1.5px solid var(--muted);
        border-radius: 50%;
        flex-shrink: 0;
        transition: border-color .15s, background .15s;
    }
    .lang-option input[type="radio"]:checked
    {
        border-color: var(--accent);
        background: var(--accent);
        box-shadow: 0 0 8px rgba(0,229,255,.5);
    }
    .lang-option input[type="radio"]:checked::after
    {
        content: '';
        display: block;
        width: 5px;
        height: 5px;
        background: var(--bg);
        border-radius: 50%;
        margin: 3px auto 0;
    }
    .lang-option:has(input:checked)::before
    {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 2px;
        background: var(--accent);
        box-shadow: 0 0 6px var(--accent);
    }
    .lang-option .lang-label
    {
        font-size: 13px;
        color: var(--muted);
        transition: color .15s;
    }
    .lang-option:has(input:checked) .lang-label
    {
        color: var(--accent);
    }
    .right-pane
    {
        display: grid;
        grid-template-rows: 1fr auto;
        overflow: hidden;
    }
    .pane-bar
    {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 18px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        font-size: 11px;
        letter-spacing: .12em;
        color: var(--muted);
        text-transform: uppercase;
        font-family: var(--font-ui);
    }
     /* EDITOR  */
    .editor-section
    {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    #compiler-form
    {
        display: flex;
        flex-direction: column;
        flex: 1;
        overflow: hidden;
    }
    #code-input
    {
        flex: 1;
        width: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-code);
        font-size: 14px;
        line-height: 1.75;
        border: none;
        outline: none;
        resize: none;
        padding: 20px 24px;
        tab-size: 4;
        caret-color: var(--accent);
        min-height: 260px;
    }
    #code-input::placeholder
    {
        color: var(--muted);
    }
    #code-input::selection
    {
        background: rgba(0,229,255,.15);
    }
    .run-row
    {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 18px;
        background: var(--surface);
        border-top: 1px solid var(--border);
    }
    #run-btn
    {
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        background: var(--accent);
        color: var(--bg);
        border: none;
        padding: 10px 30px;
        cursor: pointer;
        clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
        transition: box-shadow .2s, transform .1s;
    }
    #run-btn:hover
    {
        box-shadow: 0 0 28px rgba(0,229,255,.55);
        transform: translateY(-1px);
    }
    #run-btn:active
    {
        transform: translateY(0);
    }
    #run-btn:disabled
    {
        opacity: .4;
        cursor: not-allowed;
    }
    .shortcut-hint
    {
        font-size: 11px;
        color: var(--muted);
        letter-spacing: .08em;
    }
    #spinner
    {
        display: none;
        width: 15px;
        height: 15px;
        border: 2px solid var(--muted);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin .7s linear infinite;
    }
    @@keyframes spin
    {
        to
        {
            transform: rotate(360deg);
        }
    }
    /* STUFF FOR RESPONSIVITY */
    @@media (max-width: 700px)
    {
        .workspace
        {
            grid-template-columns: 1fr;
            grid-template-rows: auto 1fr;
        }
        .lang-sidebar
        {
            flex-direction: row;
            flex-wrap: wrap;
            border-right: none;
            border-bottom: 1px solid var(--border);
            padding: 10px;
            gap: 6px;
        }
        .sidebar-title
        {
            display: none;
        }
        .lang-option
        {
            border: 1px solid var(--border);
            padding: 5px 12px;
            border-radius: var(--radius);
        }
        .lang-option:has(input:checked)
        {
            border-color: var(--accent);
            background: var(--accent-dim);
        }
        .lang-option:has(input:checked)::before
        {
            display: none;
        }
    }
</style>
}
@*
    I use the presence of Model.Output to determine whether to show the idle state
    This is computed server-side once per render
*@
@{
    string outputClass= Model.Output == null ? 
    "state-idle" : (Model.IsError ? "state-error" : "state-success");
    // double ternary to determine the appropriate CSS class for the output display based on the execution result

    string outputText= Model.Output ?? "// Output will appear here after you click Run...";
    // NOTE: ?? is the null-coalescing operator which returns the left operand 
    // if it's not null, otherwise it returns the right operand
}

<div class="workspace">
    <aside class="lang-sidebar">
        <div class="sidebar-title">Language</div>
        @* 
            Dynamically generate the radio buttons based on
            the SupportedLanguages dict in the view model
            which is populated from the CodeExecutionService
            The reason is so we only have to maintain the list of
            supported languages in one place making it easier to add/remove
        *@
        @foreach (var lang in CompilerViewModel.SupportedLanguages)
        {
            <label class="lang-option">
                <input type="radio"
                       name="SelectedLanguage"
                       value="@lang.Key"
                       form="compiler-form"
                       @(Model.SelectedLanguage == lang.Key ? "checked" : "") />
                <span class="lang-label">@lang.Value</span>
            </label>
        }
    </aside>

    <div class="right-pane">
        <section class="editor-section">
            <div class="pane-bar">
                <span>editor</span>
                <span id="active-lang-label">
                    @* 
                        Show the currently selected language in the editor pane-bar
                        We update this on both page load and 
                        whenever the user selects a different language
                    *@
                    @(CompilerViewModel.SupportedLanguages.GetValueOrDefault
                    (Model.SelectedLanguage, "unknown"))
                </span>
            </div>

            <form id="compiler-form"
                  asp-action="Run"
                  asp-controller="Compiler"
                  method="post">

                  @* 
                    Anti-forgery token for security to prevent CSRF attacks
                    NOTE: CSRF attacks are attacks where a malicious site tricks a 
                    users browser into making unwanted requests to our server
                    where theyre already authenticated
                  *@
                @Html.AntiForgeryToken()
                <textarea id="code-input"
                          asp-for="Code"
                          spellcheck="false"
                          autocomplete="off"
                          autocorrect="off"
                          autocapitalize="off">
                          @Model.Code
                </textarea>

                <div class="run-row">
                    <button type="submit" id="run-btn">&#9654; Run</button>
                    <div id="spinner"></div>
                    <span class="shortcut-hint">Ctrl + Enter</span>
                </div>

            </form>
        </section>

        <section class="output-section">

            <div class="pane-bar">
                <span>output</span>
                <span>
                    @* 
                        Show the time it took to run
                        color codded based on sucess/error
                    *@
                    @if (Model.ExecutionTimeMs.HasValue)
                    {
                        <span class="@(Model.IsError ? "meta-err" : "meta-ok")">
                            @Model.ExecutionTimeMs ms
                        </span>
                    }
                    else
                    {
                        // this is the numerical represantation of the - (emdash) char
                        <span>&#8212;</span>
                        // to my understanding its better to use this representation
                        // thanks to editor rules preventing liberal use of special chars
                    }
                </span>
            </div>

            <p id="output-display" class="@outputClass">@outputText</p>

            <div class="output-meta">
                @* 
                    Were displaying some metadata about the execution like which 
                    language was used and whether it was a success
                    This is all done server side and rendered on each page load (after POST) 
                    since we need to know the output to determine the success/error status
                *@
                @if (Model.Output != null)
                {
                    <span class="@(Model.IsError ? "meta-err" : "meta-ok")">
                        @(Model.IsError ? "error" : "success")
                    </span>
                    <span>@Model.SelectedLanguage</span>
                    @if (Model.ExecutionTimeMs.HasValue)
                    {
                        <span>@Model.ExecutionTimeMs ms</span>
                    }
                }
                else
                {
                    <span>ready</span>
                }
            </div>

        </section>
    </div>
</div>

@section Scripts
{
<script>
(function ()
{
    "use strict";
    /*
    little QOL i made for myself as it got tedious to constantly write the same code snippet
    to test the running of different langs with their most (relatively) basic snippets
    NOTE: KEY must match the radio button value in CompilerViewModel.SupportedLanguages.
    NOTE2: this is intended to work only
    When the user selects a language AND the editor is empty (or still
    showing a previous snippet) then the new snippet replaces the textarea content
    the intention is so this QOL doesnt overwrite any code the users wrote if 
    they accidently switch langs because 
    yes that happened (too often, way too often) and yes its annoying
    */
    var helloWorld= {
        "py": 'print("Hello, World!")',
        "js": 'console.log("Hello, World!");',
        "ts": 'console.log("Hello, World!");',
        "c": '#include <stdio.h>\n\nint main() {\n    printf("Hello, World!\\n");\n    return 0;\n}',
        "cpp": '#include <iostream>\n\nint main() {\n    std::cout << "Hello, World!" << std::endl;\n    return 0;\n}'
    };

    var textarea= document.getElementById('code-input');
    var form= document.getElementById('compiler-form');
    var runBtn= document.getElementById('run-btn');
    var spinner= document.getElementById('spinner');
    var langLabel= document.getElementById('active-lang-label');
    var radioInputs= document.querySelectorAll('input[name="SelectedLanguage"]');

    // On page load: if the textarea is empty, fill with the default (which should be python)
    (function seedInitialSnippet()
    {
        if (textarea.value.trim() !== '') return;  // case of having code so skip (no overwrite)

        var checked= document.querySelector('input[name="SelectedLanguage"]:checked');
        if (checked && helloWorld[checked.value])
        {
            textarea.value= helloWorld[checked.value];
        }
    }());

    // When a language radio button is selected, swap the snippet
    // We only replace the content if it currently matches one of the
    // known snippets (or is blank) otherwise leave it be
    function isSnippetContent(text)
    {
        var t= text.trim();
        if (t === '') return true;// edge case of blank content
        for (var key in helloWorld)
        {
            // hasOwnProperty check to avoid prototype properties 
            // and ensures we're only comparing against our defined snippets
            if (helloWorld.hasOwnProperty(key) && t === helloWorld[key].trim())
            {
                return true;
            }
        }
        return false;
    }
    radioInputs.forEach(function (radio)
    {
        radio.addEventListener('change', function ()
        {
            if (!radio.checked) return;

            // Update the pane-bar label
            var labelSpan= radio.closest('.lang-option').querySelector('.lang-label');
            if (labelSpan) langLabel.textContent= labelSpan.textContent;

            // Replace textarea only if it's blank or still showing a snippet
            if (isSnippetContent(textarea.value)) {
                textarea.value = helloWorld[radio.value] || '';
            }
        });
    });
    // another QOL that makes Ctrl+Enter submits the form 
    // used to just speed up the testing process
    textarea.addEventListener('keydown', function (e)
    {
        if (e.ctrlKey && e.key === 'Enter')
        {
            e.preventDefault();
            form.requestSubmit();
        }
    });

    // My attempt to mimic some editor like behavior where
    // tab inserts 4 spaces instead of shifting focus
    textarea.addEventListener('keydown', function (e)
    {
        if (e.key === 'Tab')
        {
            e.preventDefault();
            document.execCommand('insertText', false, '    ');
        }
    });
    // some visual feedback for the user to communicate that shit is happening by
    // showing a spinner type img/icon while waiting for server response
    form.addEventListener('submit', function () {
        runBtn.disabled       = true;
        runBtn.style.display  = 'none';
        spinner.style.display = 'block';
    });
}());
</script>
}
